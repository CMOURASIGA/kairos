# URL publica da aplicacao local/producao
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase Project Settings > API > Project URL
NEXT_PUBLIC_SUPABASE_URL=

# Supabase Project Settings > API > Project API Keys > anon public
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# OpenAI Dashboard > API keys
OPENAI_API_KEY=

# Supabase Project Settings > API > service_role secret
SUPABASE_SERVICE_ROLE_KEY=

# Opcional: enquanto nao houver login, usuario padrao para persistencia
KAIROS_DEFAULT_USER_ID=00000000-0000-0000-0000-000000000001

# Opcional: se definido, exige autenticacao por header em APIs operacionais
KAIROS_API_KEY=

# OpenAI TTS model inicial
OPENAI_TTS_MODEL=gpt-4o-mini-tts

# OpenAI TTS voice inicial
OPENAI_TTS_VOICE=sage

# OpenAI embedding model para memoria semantica
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Memory Compression Engine (opcional)
KAIROS_MEMORY_COMPRESSION_MAX_ACTIVE=120
KAIROS_MEMORY_COMPRESSION_TARGET_ACTIVE=80
KAIROS_MEMORY_COMPRESSION_MIN_BATCH=10
KAIROS_MEMORY_COMPRESSION_MAX_BATCH=30
KAIROS_MEMORY_COMPRESSION_MODEL=gpt-4o-mini

# Memory Priority System (opcional)
KAIROS_PRIORITY_STALE_DAYS=30
KAIROS_PRIORITY_BATCH_LIMIT=120

# Daily AI (opcional)
KAIROS_DAILY_MODEL=gpt-4o-mini

# Integracoes (opcional - US-024 base)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Gmail (US-025)
GMAIL_ACCESS_TOKEN=
GMAIL_USER_ID=me

# Google Calendar (US-026)
GOOGLE_CALENDAR_ACCESS_TOKEN=
GOOGLE_CALENDAR_ID=primary

# Google Drive (US-027)
GOOGLE_DRIVE_ACCESS_TOKEN=

AZURE_DEVOPS_ORG_URL=
AZURE_DEVOPS_PAT=
AZURE_DEVOPS_PROJECT=
N8N_BASE_URL=
N8N_API_KEY=
N8N_WEBHOOK_BASE_URL=
